# test observing / getter-like list methods:

let items = [null, true, false];

# test length getter
let count = items @ len();

# test valid index yielding 
let good = items @ at(1);

# test OOB index yielding null
let bad = items @ at(3);

let found = items @ find(true);

let unfound = items @ find(1);

print(count, good, bad, found, unfound);

true;
